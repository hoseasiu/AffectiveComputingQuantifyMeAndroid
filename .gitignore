# Built application files
*.apk
*.ap_
*.aab

# Files for the Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ / Android Studio project files
*.iml
.idea/

# Keystore files
*.jks
*.keystore
keystore.properties

# External native build folder
.externalNativeBuild
.cxx/

# Google Services (e.g. APIs or Firebase)
google-services.json

# Freeline
freeline.py
freeline/
freeline_project_description.json

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/readme.md

# Version control
vcs.xml

# lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/
lint/reports/

# macOS
.DS_Store

# Project-specific: real backend URL / crash-reporting creds, never checked in
base_url.xml

# NOTE: AGENT_PLANS/ used to be ignored here. It is now tracked, deliberately —
# being ignored meant no history and no backup, and the directory was eventually
# destroyed outright (a worktree junction plus a recursive delete). The churny
# "who is working on what" table that justified ignoring it is gone; that state is
# now derived by scripts/agent-status.ps1 and claimed via GitHub labels instead.
# See CLAUDE.md, "Agent coordination".

# root-level PDF files
/*.pdf

# Claude Code state. Everything under .claude/ is machine-local EXCEPT skills/, which
# is tracked deliberately so ordinary checkout delivers it to every agent worktree
# (same reasoning as AGENT_PLANS/ above). Without the blanket ignore, a `git add -A`
# would sweep in .claude/worktrees/ — every agent worktree, build output included.
.claude/*
!.claude/skills/