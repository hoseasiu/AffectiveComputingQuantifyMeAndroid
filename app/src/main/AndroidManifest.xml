<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools" >

    <!-- Required since API 33 to actually display the WorkManager-driven daily check-in
         reminder notification; requested at runtime from SettingsActivity/MainActivity. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Health Connect (Phase 3 replacement for the dead Jawbone UP SDK) -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />

    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <application
        android:allowBackup="false"
        android:icon="@mipmap/icon"
        android:label="@string/app_label"
        android:name=".MyApplication"
        android:theme="@style/BaseStyle"
        tools:replace="android:icon,android:label" >

        <activity
            android:name="edu.mit.media.mysnapshot.activities.MainActivity"
            android:launchMode="singleTask"
            android:exported="true"
            android:label="@string/title_activity_main" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="edu.mit.media.mysnapshot.activities.SettingsActivity"
            android:launchMode="singleTask"
            android:label="Settings" >
        </activity>
        <activity
            android:name="edu.mit.media.mysnapshot.activities.IntroActivity"
            android:launchMode="singleTask"
            android:label="@string/title_activity_main" >
        </activity>
        <activity
            android:name="edu.mit.media.mysnapshot.activities.IntroThanksActivity"
            android:launchMode="singleTask"
            android:label="@string/title_activity_main" >
        </activity>

        <activity
            android:name=".activities.ExperimentChooseActivity"
            android:launchMode="singleTask"
            android:label="@string/title_activity_main" >
        </activity>
        <activity
            android:name=".activities.ExperimentIntroActivity"
            android:launchMode="singleTask"
            android:label="@string/title_activity_main" >
        </activity>
        <activity
            android:name="edu.mit.media.mysnapshot.activities.ExperimentConfigActivity"
            android:launchMode="singleTask"
            android:label="@string/title_activity_main" >
        </activity>
        <activity
            android:name="edu.mit.media.mysnapshot.activities.ExperimentCreatedActivity"
            android:launchMode="singleTask"
            android:label="@string/title_activity_main" >
        </activity>
        <activity
            android:name="edu.mit.media.mysnapshot.activities.ExperimentCheckinActivity"
            android:launchMode="singleTask"
            android:label="@string/title_activity_main" >
        </activity>
        <activity
            android:name=".activities.ExperimentInstructionsActivity"
            android:launchMode="singleTask"
            android:label="@string/title_activity_main" >
        </activity>
        <activity
            android:name="edu.mit.media.mysnapshot.activities.ExperimentCompleteActivity"
            android:launchMode="singleTask"
            android:label="@string/title_activity_main" >
        </activity>
        <activity
            android:name="edu.mit.media.mysnapshot.activities.HistoryActivity"
            android:launchMode="singleTask"
            android:label="@string/title_activity_main" >
        </activity>
        <activity
            android:name="edu.mit.media.mysnapshot.activities.ExperimentProgressActivity"
            android:label="@string/title_activity_main" >
        </activity>

        <!-- WorkManager's default on-demand initializer would build a plain (non-Hilt)
             WorkManager instance before MyApplication.onCreate runs; remove it so
             MyApplication's Configuration.Provider (HiltWorkerFactory-backed) is used
             instead, letting CheckinReminderWorker use @HiltWorker/@AssistedInject. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Backs the user-initiated "export my data" share sheet (HistoryActivity /
             ExperimentExporter). Exported JSON files live under cacheDir/exports and are
             handed to the share target via a content:// URI, never written to shared/external
             storage and never uploaded anywhere by the app itself. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
