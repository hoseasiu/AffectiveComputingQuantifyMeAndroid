<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="FontTextView">
        <attr name="customtypeface" format="enum">
            <enum name="Montserrat" value="0" />
            <enum name="Montserrat_Bold" value="1" />
            <enum name="Raleway" value="2" />
            <enum name="Raleway_Semibold" value="3" />
            <enum name="Raleway_Light" value="4" />
        </attr>
        <attr name="usehtml" format="boolean" />
    </declare-styleable>

</resources>